<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_l10n_id_payroll_settings_list" model="ir.ui.view">
        <field name="name">l10n_id.payroll.settings.list</field>
        <field name="model">l10n_id.payroll.settings</field>
        <field name="arch" type="xml">
            <list>
                <field name="company_id"/>
                <field name="effective_date"/>
                <field name="pph21_method"/>
                <field name="thr_policy"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_id_payroll_settings_form" model="ir.ui.view">
        <field name="name">l10n_id.payroll.settings.form</field>
        <field name="model">l10n_id.payroll.settings</field>
        <field name="arch" type="xml">
            <form string="Indonesian Payroll Settings">
                <sheet>
                    <group>
                        <group>
                            <field name="company_id"/>
                            <field name="effective_date"/>
                            <field name="pph21_method"/>
                            <field name="thr_policy"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="BPJS">
                            <group>
                                <group string="Health">
                                    <field name="bpjs_kesehatan_employee_rate"/>
                                    <field name="bpjs_kesehatan_employer_rate"/>
                                    <field name="bpjs_kesehatan_cap"/>
                                </group>
                                <group string="Employment">
                                    <field name="bpjs_jht_employee_rate"/>
                                    <field name="bpjs_jht_employer_rate"/>
                                    <field name="bpjs_jp_employee_rate"/>
                                    <field name="bpjs_jp_employer_rate"/>
                                    <field name="bpjs_jp_cap"/>
                                    <field name="bpjs_jkk_employer_rate"/>
                                    <field name="bpjs_jkm_employer_rate"/>
                                </group>
                            </group>
                            <group>
                                <field name="bpjs_note" placeholder="Update rates and wage caps to the latest statutory references before production use."/>
                            </group>
                        </page>
                        <page string="PPh21">
                            <group>
                                <field name="pph21_note" placeholder="Document TER/progressive assumptions, PTKP rules, and reconciliation notes here."/>
                            </group>
                        </page>
                        <page string="THR">
                            <group>
                                <field name="thr_note" placeholder="Document THR eligibility, proration, and business policies here."/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_id_payroll_structure_list" model="ir.ui.view">
        <field name="name">l10n_id.payroll.structure.list</field>
        <field name="model">l10n_id.payroll.structure</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_id_payroll_structure_form" model="ir.ui.view">
        <field name="name">l10n_id.payroll.structure.form</field>
        <field name="model">l10n_id.payroll.structure</field>
        <field name="arch" type="xml">
            <form string="Indonesian Payroll Structure">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="company_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="note" placeholder="Explain how this structure should evolve or integrate with a future payroll engine."/>
                    </group>
                    <field name="rule_ids">
                        <list editable="bottom">
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="category"/>
                            <field name="rule_type"/>
                            <field name="amount_type"/>
                            <field name="amount_fixed" optional="hide"/>
                            <field name="appears_on_payslip"/>
                        </list>
                        <form string="Indonesian Payroll Rule">
                            <group>
                                <group>
                                    <field name="name"/>
                                    <field name="code"/>
                                    <field name="sequence"/>
                                    <field name="category"/>
                                    <field name="rule_type"/>
                                    <field name="amount_type"/>
                                    <field name="amount_fixed" invisible="amount_type != 'fixed'"/>
                                    <field name="appears_on_payslip"/>
                                    <field name="active"/>
                                </group>
                            </group>
                            <group>
                                <field name="python_expression" invisible="amount_type != 'python'" placeholder="Example: result = contract.wage or 0.0"/>
                                <field name="note" placeholder="Explain legal assumptions, missing edge cases, or planned follow-up work."/>
                            </group>
                        </form>
                    </field>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_id_payroll_rule_list" model="ir.ui.view">
        <field name="name">l10n_id.payroll.rule.list</field>
        <field name="model">l10n_id.payroll.rule</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"/>
                <field name="name"/>
                <field name="code"/>
                <field name="structure_id"/>
                <field name="category"/>
                <field name="rule_type"/>
                <field name="amount_type"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_id_payroll_rule_form" model="ir.ui.view">
        <field name="name">l10n_id.payroll.rule.form</field>
        <field name="model">l10n_id.payroll.rule</field>
        <field name="arch" type="xml">
            <form string="Indonesian Payroll Rule">
                <sheet>
                    <group>
                        <group>
                            <field name="structure_id"/>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="sequence"/>
                            <field name="category"/>
                            <field name="rule_type"/>
                            <field name="amount_type"/>
                            <field name="amount_fixed" invisible="amount_type != 'fixed'"/>
                            <field name="appears_on_payslip"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group>
                        <field name="python_expression" invisible="amount_type != 'python'" placeholder="Use this as a developer hint until a calculation engine is implemented."/>
                        <field name="note" placeholder="Describe incomplete logic and statutory assumptions here."/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_id_payroll_settings" model="ir.actions.act_window">
        <field name="name">Payroll Settings</field>
        <field name="res_model">l10n_id.payroll.settings</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_l10n_id_payroll_structures" model="ir.actions.act_window">
        <field name="name">Payroll Structures</field>
        <field name="res_model">l10n_id.payroll.structure</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="action_l10n_id_payroll_rules" model="ir.actions.act_window">
        <field name="name">Payroll Rules</field>
        <field name="res_model">l10n_id.payroll.rule</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_l10n_id_hr_payroll_root" name="Indonesian Payroll" parent="hr.menu_hr_root" sequence="80" groups="hr.group_hr_user"/>
    <menuitem id="menu_l10n_id_payroll_settings" name="Settings" parent="menu_l10n_id_hr_payroll_root" action="action_l10n_id_payroll_settings" sequence="10" groups="hr.group_hr_manager"/>
    <menuitem id="menu_l10n_id_payroll_structures" name="Structures" parent="menu_l10n_id_hr_payroll_root" action="action_l10n_id_payroll_structures" sequence="20" groups="hr.group_hr_user"/>
    <menuitem id="menu_l10n_id_payroll_rules" name="Rules" parent="menu_l10n_id_hr_payroll_root" action="action_l10n_id_payroll_rules" sequence="30" groups="hr.group_hr_user"/>
</odoo>
