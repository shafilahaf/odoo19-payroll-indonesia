<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_employee_form_l10n_id_payroll" model="ir.ui.view">
        <field name="name">hr.employee.form.l10n.id.payroll</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Indonesian Payroll" groups="hr.group_hr_user">
                    <group>
                        <group string="Tax Profile">
                            <field name="l10n_id_nik"/>
                            <field name="l10n_id_npwp"/>
                            <field name="l10n_id_npwp_name"/>
                            <field name="l10n_id_ptkp_status"/>
                            <field name="l10n_id_tax_method"/>
                        </group>
                        <group string="BPJS">
                            <field name="l10n_id_bpjs_kesehatan"/>
                            <field name="l10n_id_bpjs_kesehatan_no" invisible="not l10n_id_bpjs_kesehatan"/>
                            <field name="l10n_id_bpjs_ketenagakerjaan"/>
                            <field name="l10n_id_bpjs_ketenagakerjaan_no" invisible="not l10n_id_bpjs_ketenagakerjaan"/>
                            <field name="l10n_id_bpjs_join_date"/>
                        </group>
                    </group>
                    <group>
                        <field name="l10n_id_payroll_note" placeholder="Use this area for payroll localization assumptions or manual exceptions."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
