<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- TER Category Tree View -->
    <record id="pph21_ter_category_view_tree" model="ir.ui.view">
        <field name="name">pph21.ter.category.tree</field>
        <field name="model">pph21.ter.category</field>
        <field name="arch" type="xml">
            <tree>
                <field name="code"/>
                <field name="name"/>
                <field name="description"/>
            </tree>
        </field>
    </record>

    <!-- TER Category Form View -->
    <record id="pph21_ter_category_view_form" model="ir.ui.view">
        <field name="name">pph21.ter.category.form</field>
        <field name="model">pph21.ter.category</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="PTKP Status" name="ptkp">
                            <field name="ptkp_ids">
                                <tree>
                                    <field name="code"/>
                                    <field name="name"/>
                                    <field name="annual_amount"/>
                                </tree>
                            </field>
                        </page>
                        <page string="TER Rates" name="rates">
                            <field name="rate_ids">
                                <tree editable="bottom">
                                    <field name="range_from"/>
                                    <field name="range_to"/>
                                    <field name="rate"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- TER Category Action -->
    <record id="action_pph21_ter_category" model="ir.actions.act_window">
        <field name="name">TER Categories</field>
        <field name="res_model">pph21.ter.category</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a TER Category
            </p>
            <p>
                TER Categories (A, B, C) are based on PTKP status and determine 
                which effective tax rate table to use for monthly PPh 21 calculation.
            </p>
        </field>
    </record>

</odoo>
