<?xml version="1.0" encoding="utf-8"?>
<!--
    Payslip view extension for Indonesian PPh21.

    This file inherits from hr_payroll.view_hr_payslip_form which is the standard
    payslip form view provided by the Enterprise payroll engine.

    In Odoo 19 Enterprise, hr_payroll is typically installed as a transitive dependency
    of hr_contract_salary_payroll, so its XML IDs remain accessible even though
    hr_payroll is not listed directly in this addon's depends.

    If the payslip form view in your environment uses a different XML ID (for example
    from a custom Enterprise payroll module), update the ref attribute on inherit_id
    below to match.  Common alternatives:
      - hr_contract_salary_payroll.view_hr_payslip_form
      - payroll.view_hr_payslip_form
-->
<odoo>
    <record id="view_hr_payslip_form_l10n_id_pph21" model="ir.ui.view">
        <field name="name">hr.payslip.form.l10n.id.pph21</field>
        <field name="model">hr.payslip</field>
        <field name="inherit_id" ref="hr_payroll.view_hr_payslip_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Indonesian PPh21" groups="hr.group_hr_user">
                    <group>
                        <group string="Placeholder Output">
                            <field name="l10n_id_pph21_method" readonly="1"/>
                            <field name="l10n_id_pph21_tax_status" readonly="1"/>
                            <field name="l10n_id_pph21_monthly_taxable_income" readonly="1"/>
                            <field name="l10n_id_pph21_placeholder_rate" readonly="1"/>
                            <field name="l10n_id_pph21_amount" readonly="1"/>
                            <field name="l10n_id_pph21_rule_code" readonly="1"/>
                        </group>
                    </group>
                    <group string="Breakdown">
                        <field name="l10n_id_pph21_breakdown" nolabel="1" readonly="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
