<?xml version="1.0" encoding="utf-8"?>
<!--
    Contract Template / Salary Package view extension for Indonesian PPh21.

    This file extends hr.version (the Contract Template / Salary Package model provided
    by hr_contract_salary in Odoo 19 Enterprise).

    The inherit_id below uses the standard hr_contract_salary form view for hr.version.
    If your Odoo 19 Enterprise distribution uses a different XML ID for the hr.version
    form view, update the ref attribute on the inherit_id field accordingly.
    Common alternatives to check:
      - hr_contract_salary.hr_version_view_form_salary
      - hr_contract_salary.view_hr_version_form
-->
<odoo>
    <record id="hr_version_view_form_l10n_id_pph21" model="ir.ui.view">
        <field name="name">hr.version.form.l10n.id.pph21</field>
        <field name="model">hr.version</field>
        <field name="inherit_id" ref="hr_contract_salary.hr_version_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Indonesian PPh21" groups="hr.group_hr_user">
                    <group>
                        <group string="Method and Timing">
                            <field name="l10n_id_pph21_method"/>
                            <field name="l10n_id_pph21_effective_date"/>
                            <field name="l10n_id_pph21_annual_reconciliation" invisible="l10n_id_pph21_method != 'progressive'"/>
                        </group>
                        <group string="Placeholder Inputs">
                            <field name="l10n_id_pph21_additional_taxable_amount"/>
                            <field name="l10n_id_pph21_override_active"/>
                            <field name="l10n_id_pph21_override_amount" invisible="not l10n_id_pph21_override_active"/>
                        </group>
                    </group>
                    <group>
                        <field
                            name="l10n_id_pph21_note"
                            placeholder="Track salary-package-specific taxable components, temporary overrides, or future statutory notes."
                        />
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
